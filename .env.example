# Copy to .env and adjust. All values have sensible defaults.

# Port the portal listens on
PORT=3000

# Secret used to sign login sessions. REQUIRED in production — the server
# refuses to start without it (no insecure default is allowed). Use a long
# random string, e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=change-me-to-a-long-random-string

# Office timezone (controls what counts as "today" for clock-in)
TZ_OFFICE=Asia/Kolkata

# Punctuality (Monthly KPIs): a clock-in counts as on time if it's by the
# employee's shift start (set per person on their profile) plus the grace window.
# SHIFT_START_HOUR is only the FALLBACK for employees whose profile shift start
# is blank. Default fallback 16:00 (4 PM) with 15 min grace.
SHIFT_START_HOUR=16
SHIFT_GRACE_MIN=15

# Where the SQLite database file lives. On Railway, point this at the volume,
# e.g. /data/portal.db
DB_PATH=./data/portal.db

# Set to "production" when deployed (enables secure cookies over HTTPS)
NODE_ENV=development

# Optional: a long random secret that lets a scheduled script download the
# database backup without logging in, via /api/backup?token=<this>. Leave
# unset to allow backups only from a logged-in admin (the in-app button).
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
BACKUP_TOKEN=

# Optional: email a data backup automatically every week + every month
# (Excel-openable CSVs + the .db file). Off unless SMTP is configured below.
# Gmail: turn on 2-Step Verification, create an App Password, then use:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_USER=you@gmail.com
#   SMTP_PASS=<16-char app password>  BACKUP_EMAIL_TO=you@welitnexus.com
# BACKUP_EMAIL_HOUR is the office-zone hour it sends (default 6 AM);
# BACKUP_WEEKLY_DOW is the weekly day (1=Mon .. 7=Sun, default 1).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
BACKUP_EMAIL_FROM=
BACKUP_EMAIL_TO=
BACKUP_EMAIL_HOUR=6
BACKUP_WEEKLY_DOW=1

# Optional: post a daily attendance summary (everyone's worked hours + break)
# to Slack. Create an Incoming Webhook in Slack, paste its URL here, and set
# the hour (office timezone, 24h). Leave the URL blank to disable.
SLACK_WEBHOOK_URL=
SLACK_SUMMARY_HOUR=3

# Optional: also send in-app notifications (leave decisions, task assignments,
# punch-correction decisions, announcements) as personal Slack DMs. Leave blank
# to keep notifications in-app only. To enable, create/reuse a Slack app with a
# Bot User OAuth token (starts with xoxb-) that has these scopes:
#   users:read.email, chat:write, im:write
# Employees are matched to Slack automatically by email, so their portal email
# must match their Slack email. Paste the bot token here.
SLACK_BOT_TOKEN=

# Auto-absence flagging: once a day, employees who normally clock in but didn't
# (for the shift that just ended) get a PENDING leave request for admins to
# approve or reject. Nothing is deducted until an admin approves. Set to "off"
# to disable. ABSENCE_CHECK_HOUR is the office-zone hour it runs (default 10,
# safely after the 8 AM shift cutover).
AUTO_ABSENCE=on
ABSENCE_CHECK_HOUR=10

# First-boot admin. On a brand-new (empty) database the server auto-creates
# ONE admin from these values so you can log in right away. Ignored once any
# user exists. Change the password from inside the app after first login.
# In production ADMIN_PASSWORD is required — without it the server skips admin
# creation rather than using a known default.
ADMIN_NAME=Saurav Garg
ADMIN_EMAIL=saurav@welitnexus.com
ADMIN_PASSWORD=ChangeMe@2026
