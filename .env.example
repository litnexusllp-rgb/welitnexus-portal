# Copy to .env and adjust. All values have sensible defaults.

# Port the portal listens on
PORT=3000

# Secret used to sign login sessions — MUST be a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# Office timezone (controls what counts as "today" for clock-in)
TZ_OFFICE=Asia/Kolkata

# Where the SQLite database file lives. On Railway, point this at the volume,
# e.g. /data/portal.db
DB_PATH=./data/portal.db

# Set to "production" when deployed (enables secure cookies over HTTPS)
NODE_ENV=development

# First-boot admin. On a brand-new (empty) database the server auto-creates
# ONE admin from these values so you can log in right away. Ignored once any
# user exists. Change the password from inside the app after first login.
ADMIN_NAME=Saurav Garg
ADMIN_EMAIL=saurav@welitnexus.com
ADMIN_PASSWORD=ChangeMe@2026
